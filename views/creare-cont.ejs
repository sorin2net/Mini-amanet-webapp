<form action="/procesare-inregistrare" method="POST" style="max-width: 450px; margin: 0 auto; background: var(--bg-main); padding: 30px; border-radius: 8px; border: 1px solid var(--border-color);">
    <h2 style="color: var(--accent-color); text-align: center; margin-top: 0; margin-bottom: 25px;">Creare Cont Nou</h2>
    
    <% if (typeof eroare !== 'undefined' && eroare) { %>
        <div style="background-color: var(--error-bg); color: var(--error-color); padding: 10px; border-radius: 6px; border: 1px solid var(--error-color); margin-bottom: 20px; text-align: center; font-weight: bold;">
            <%= eroare %>
        </div>
    <% } %>

    <fieldset style="border: none; padding: 0; margin: 0;">
        <label style="display: block; margin-bottom: 15px;">
            <span style="display: block; margin-bottom: 5px; color: var(--text-muted);">Nume (Familie):</span>
            <input type="text" name="nume" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border-color); background: #1a1a1a; color: white; box-sizing: border-box;">
        </label>

        <label style="display: block; margin-bottom: 15px;">
            <span style="display: block; margin-bottom: 5px; color: var(--text-muted);">Prenume:</span>
            <input type="text" name="prenume" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border-color); background: #1a1a1a; color: white; box-sizing: border-box;">
        </label>

        <label style="display: block; margin-bottom: 15px;">
            <span style="display: block; margin-bottom: 5px; color: var(--text-muted);">Nume Utilizator (Username):</span>
            <input type="text" name="utilizator" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border-color); background: #1a1a1a; color: white; box-sizing: border-box;">
        </label>
        
        <label style="display: block; margin-bottom: 25px;">
            <span style="display: block; margin-bottom: 5px; color: var(--text-muted);">Parolă:</span>
            <input type="password" name="parola" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border-color); background: #1a1a1a; color: white; box-sizing: border-box;">
        </label>
    </fieldset>

    <button type="submit" style="width: 100%; background-color: var(--accent-color); color: #000; font-weight: bold; padding: 12px; border: none; border-radius: 4px; cursor: pointer; font-size: 16px;">Înregistrare</button>
    
    <div style="text-align: center; margin-top: 20px;">
        <span style="color: var(--text-muted);">Ai deja cont? </span>
        <a href="/autentificare" style="color: var(--accent-color); text-decoration: none; font-weight: bold;">Loghează-te aici</a>
    </div>
    <div style="text-align: center; margin-top: 15px;">
        <a href="/" style="color: var(--text-muted); text-decoration: none; font-size: 14px;">&larr; Înapoi la Magazin</a>
    </div>
</form>